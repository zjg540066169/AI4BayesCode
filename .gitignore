# ── OS / editor ───────────────────────────────────────────────
.DS_Store
*~
.idea/
.vscode/

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.venv/
venv/

# ── R ─────────────────────────────────────────────────────────
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
Rplots.pdf
r-pkg/src/*.o
r-pkg/src/*.so
r-pkg/src/*.dll
r-pkg/..Rcheck/
r-pkg/*.tar.gz

# ── generated / build outputs ─────────────────────────────────
generated/
PROMPT.txt
*.tar.gz
*.whl

# ── backups / archives (never commit) ─────────────────────────
*.bak
*.bak.*
*.bak_*
*.orig
*_BACKUP_*
*_DRAFT.md
_archive/
# macOS / iCloud duplication artifacts ("foo 2.hpp", "foo 2.txt", ...).
# NB: unquoted — .gitignore treats quotes as literal, so the old "* 2.md" never matched.
* 2.*
# stray one-off dev backups (e.g. old NUTS-kernel experiments)
*.optA
*.patched
*.cache_v1_broken

# ── logs + compiled test binaries (sources + Makefile stay tracked) ──
*.log
tests/test_*
!tests/test_*.cpp
!tests/test_*.h
!tests/test_*.hpp
!tests/test_*.R

# R CMD check / build artifacts
*.Rcheck/
AI4BayesCode_*.tar.gz
